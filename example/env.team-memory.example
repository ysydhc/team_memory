# Copy to repo root as `.env` (gitignored). Do not commit real keys.
#
# Required for MCP stdio auth + default project (see src/team_memory/utils/project.py).
TEAM_MEMORY_API_KEY=
TEAM_MEMORY_PROJECT=team_memory

# Optional: override Python used by scripts/run_mcp_with_dotenv.sh (default: .venv/bin/python)
# PYTHON=/absolute/path/to/python

# Optional: tm-cli / curl against local Web (default http://localhost:9111)
# TM_BASE_URL=http://localhost:9111

# Optional: documented for ops; MCP server.py does not read this for stdio auth (identity comes from API key).
# TEAM_MEMORY_USER=admin
