<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.teammemory.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd __REPO_ROOT__ &amp;&amp; set -a &amp;&amp; source .env &amp;&amp; set +a &amp;&amp; exec __PYTHON_PATH__ -m daemon</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__REPO_ROOT__</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>__REPO_ROOT__/src:__REPO_ROOT__/scripts</string>
        <key>LOG_FORMAT</key>
        <string>json</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/tmp/tm-daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/tm-daemon.err</string>
</dict>
</plist>
